# ========================================
# CONFIGURATION DÉVELOPPEMENT
# ========================================
# Copier ce fichier en .env.development et remplir les valeurs
#
# Usage:
#   cp .env.example .env.development
#
# ATTENTION: Ne jamais commiter de fichier .env avec des vrais secrets !

# ========================================
# ENVIRONNEMENT
# ========================================
NODE_ENV=development

# ========================================
# SERVEUR
# ========================================
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# ========================================
# BASE DE DONNÉES
# ========================================
# Format: postgresql://user:password@host:port/database?options
DATABASE_URL=postgresql://user:password@host:port/database

# ========================================
# SÉCURITÉ & AUTHENTIFICATION
# ========================================
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-minimum-32-characters
COOKIE_SECRET=your-cookie-secret-minimum-32-characters
JWT_EXPIRES_IN=24h
COOKIE_MAX_AGE=86400000
BCRYPT_ROUNDS=12

# ========================================
# CORS & SÉCURITÉ
# ========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ========================================
# EMAIL / SMTP
# ========================================
EMAIL_INTERCEPT=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=dev@example.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Passerelle CAP

# ========================================
# UPLOAD DE FICHIERS
# ========================================
UPLOADS_DIR=uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=application/pdf,image/jpeg,image/png

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=500

# ========================================
# COMPTES DE DÉMONSTRATION
# ========================================
ALLOW_DEMO_ACTIONS=true

# ========================================
# FRONTEND (Variables VITE_*)
# ========================================
VITE_ENABLE_DEMO_ACCOUNTS=true
VITE_API_URL=http://localhost:3000
VITE_STREAM_API_KEY=your-stream-api-key

# ========================================
# LOGS & DEBUG
# ========================================
LOG_LEVEL=debug
DEBUG=true

# ========================================
# CHAT STREAM.IO
# ========================================
# Obtenir les clés sur: https://getstream.io/dashboard/
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
STREAM_APP_ID=your-stream-app-id

# ========================================
# FTPS (o2switch) - Upload de fichiers
# ========================================
# Configuration FTPS pour l'upload des fichiers en production
# En développement, ces variables peuvent être laissées vides
# Les fichiers seront alors stockés localement dans uploads/
#
# IMPORTANT: Ces variables sont OBLIGATOIRES en production
#
# Hôte du serveur FTP
FTP_HOST=ftp.o2switch.com
# Port FTP (21 pour FTPS explicite)
FTP_PORT=21
# Utilisateur FTP
FTP_USER=kalo4499
# Mot de passe FTP
FTP_PASSWORD=your-ftp-password
# Utiliser FTPS (FTP sur TLS/SSL)
FTP_SECURE=true
# Répertoire de base sur le serveur FTP
FTP_BASE_DIR=/home/kalo4499/uploads/uploads
# Mode verbose pour les logs FTP (true/false)
FTP_VERBOSE=false
# Timeout de connexion en millisecondes
FTP_CONN_TIMEOUT_MS=15000
